{
    "files.exclude": {
        "out": false,
        "out-test": true,
        "node_modules": true,
        ".vscode-test": true
    },
    "search.exclude": {
        "out": true,
        "out-test": true,
        "node_modules": true
    },
    "typescript.tsc.autoDetect": "off",
    "typescript.preferences.importModuleSpecifier": "relative",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "[json]": {
        "editor.tabSize": 2
    },
    "[jsonc]": {
        "editor.tabSize": 2
    },
    "eslint.validate": ["typescript"]
}
