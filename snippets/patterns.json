{
    "-> Result Pattern": {
        "prefix": "result",
        "body": [
            "public readonly record struct Result<T>(bool IsSuccess, T? Value, string? Error)",
            "{",
            "\tpublic static Result<T> Success(T value) => new(true, value, null);",
            "\tpublic static Result<T> Failure(string error) => new(false, default, error);",
            "",
            "\tpublic TResult Match<TResult>(",
            "\t\tFunc<T, TResult> onSuccess,",
            "\t\tFunc<string, TResult> onFailure)",
            "\t\t=> IsSuccess ? onSuccess(Value!) : onFailure(Error!);",
            "}",
            "$0"
        ],
        "description": "Result/Either pattern (success or failure with payload)"
    },
    "-> Option / Maybe": {
        "prefix": "option",
        "body": [
            "public readonly record struct Option<T>(bool HasValue, T? Value)",
            "{",
            "\tpublic static Option<T> Some(T value) => new(true, value);",
            "\tpublic static Option<T> None() => new(false, default);",
            "",
            "\tpublic TResult Match<TResult>(Func<T, TResult> onSome, Func<TResult> onNone)",
            "\t\t=> HasValue ? onSome(Value!) : onNone();",
            "}",
            "$0"
        ],
        "description": "Option/Maybe monad"
    },
