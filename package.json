{
    "name": "csharp-snippet-productivity",
    "displayName": "C# Toolbox",
    "description": "Scaffold solutions, insert patterns, and ship modern C# in seconds.",
    "version": "3.0.0",
    "icon": "icon.png",
    "publisher": "richardzampieriprog",
    "license": "SEE LICENSE IN LICENSE.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/rsaz/csharp-snippet-productivity"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets",
        "Formatters"
    ],
    "keywords": [
        "C#",
        ".NET",
        ".NET Core",
        ".NET 9",
        ".NET 8",
        "scaffolding",
        "snippets",
        "productivity",
        "code generation",
        "clean architecture",
        "ddd",
        "domain driven design",
        "cqrs",
        "mediatr",
        "result pattern",
        "repository pattern",
        "specification pattern",
        "fluent builder",
        "unit of work",
        "ef core",
        "entity framework",
        "serilog",
        "fluentvalidation",
        "aspire",
        "minimal api",
        "blazor",
        "worker service",
        "dotnet new",
        "csproj",
        "nuget",
        "modern c#",
        "primary constructors",
        "file scoped namespace",
        "positional records",
        "smart comments",
        "better comments",
        "todo highlight",
        "Visual Studio",
        "keybindings"
    ],
    "extensionKind": [
        "ui"
    ],
    "activationEvents": [
        "onLanguage:csharp",
        "onLanguage:markdown",
        "onLanguage:plaintext"
    ],
    "contributes": {
        "snippets": [
            {
                "language": "csharp",
                "path": "./snippets/general.json"
            },
            {
                "language": "csharp",
                "path": "./snippets/documentxml.json"
            },
            {
                "language": "csharp",
                "path": "./snippets/designpattern.json"
            },
            {
                "language": "csharp",
                "path": "./snippets/modern.json"
            },
            {
                "language": "csharp",
                "path": "./snippets/patterns.json"
            }
        ],
        "commands": [
            {
                "command": "csharp-snippet-productivity.createProject",
                "title": "Create Project",
                "category": "C# Toolbox"
            },
            {
                "command": "csharp-snippet-productivity.createClass",
                "title": "Create Class",
                "category": "C# Toolbox"
            },
            {
                "command": "csharp-snippet-productivity.createInterface",
                "title": "Create Interface",
                "category": "C# Toolbox"
            },
            {
                "command": "csharp-snippet-productivity.createStruct",
                "title": "Create Struct",
                "category": "C# Toolbox"
            },
            {
                "command": "csharp-snippet-productivity.createRecord",
                "title": "Create Record",
                "category": "C# Toolbox"
            },
            {
                "command": "csharp-snippet-productivity.addProjectToSolution",
                "title": "Add Project",
                "category": "C# Toolbox"
            },
            {
                "command": "csharp-snippet-productivity.scaffoldCleanArchitecture",
                "title": "Scaffold Clean Architecture Solution",
                "category": "C# Toolbox"
            },
            {
                "command": "csharp-snippet-productivity.scaffoldDdd",
                "title": "Scaffold DDD Solution",
                "category": "C# Toolbox"
            },
            {
                "command": "csharp-snippet-productivity.quickAddNuget",
                "title": "Quick Add NuGet Package",
                "category": "C# Toolbox"
            },
            {
                "command": "csharp-snippet-productivity.analyzeSolution",
                "title": "Analyze Solution",
                "category": "C# Toolbox"
            },
            {
                "command": "csharp-snippet-productivity.openWalkthrough",
                "title": "Open Getting Started Walkthrough",
                "category": "C# Toolbox"
            }
        ],
        "keybindings": [
            {
                "command": "csharp-snippet-productivity.createProject",
                "key": "ctrl+alt+/ p"
            },
            {
                "command": "csharp-snippet-productivity.addProjectToSolution",
                "key": "ctrl+alt+/ a"
            },
            {
                "command": "csharp-snippet-productivity.createClass",
                "key": "ctrl+alt+/ c",
                "when": "!editorReadonly"
            },
            {
                "command": "csharp-snippet-productivity.createInterface",
                "key": "ctrl+alt+/ i",
                "when": "!editorReadonly"
            },
            {
                "command": "csharp-snippet-productivity.createStruct",
                "key": "ctrl+alt+/ s",
                "when": "!editorReadonly"
            },
            {
                "command": "csharp-snippet-productivity.createRecord",
                "key": "ctrl+alt+/ r",
                "when": "!editorReadonly"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "submenu": "cSharp.subMenu",
                    "group": "navigation@1"
                }
            ],
            "cSharp.subMenu": [
                {
                    "command": "csharp-snippet-productivity.createClass"
                },
                {
                    "command": "csharp-snippet-productivity.createInterface"
                },
                {
                    "command": "csharp-snippet-productivity.createStruct"
                },
                {
                    "command": "csharp-snippet-productivity.createRecord"
                },
                {
                    "command": "csharp-snippet-productivity.addProjectToSolution"
                }
            ],
            "commandPalette": [
                {
                    "command": "csharp-snippet-productivity.createProject",
                    "when": "true"
                },
                {
                    "command": "csharp-snippet-productivity.createClass",
                    "when": "true"
                },
                {
                    "command": "csharp-snippet-productivity.createInterface",
                    "when": "true"
                },
                {
                    "command": "csharp-snippet-productivity.createStruct",
                    "when": "true"
                },
                {
                    "command": "csharp-snippet-productivity.createRecord",
                    "when": "true"
                },
                {
                    "command": "csharp-snippet-productivity.addProjectToSolution",
                    "when": "true"
                },
                {
                    "command": "csharp-snippet-productivity.scaffoldCleanArchitecture",
                    "when": "true"
                },
                {
                    "command": "csharp-snippet-productivity.scaffoldDdd",
                    "when": "true"
                },
                {
                    "command": "csharp-snippet-productivity.quickAddNuget",
                    "when": "true"
                },
                {
                    "command": "csharp-snippet-productivity.analyzeSolution",
                    "when": "true"
                },
                {
                    "command": "csharp-snippet-productivity.openWalkthrough",
                    "when": "true"
                }
            ]
        },
        "submenus": [
            {
                "id": "cSharp.subMenu",
                "label": "C# Toolbox: Options"
            }
        ],
        "walkthroughs": [
            {
                "id": "csharp-toolbox-getting-started",
                "title": "Get started with C# Toolbox",
                "description": "Scaffold .NET projects, generate C# files, and accelerate your workflow with modern snippets and architectural patterns.",
                "steps": [
                    {
                        "id": "create-project",
                        "title": "Create your first project",
                        "description": "Launch the project creation wizard and pick from .NET 9, Aspire, Blazor, MAUI, Worker Service, and more.\n[Open Create Project](command:csharp-snippet-productivity.createProject)",
                        "media": {
                            "markdown": "walkthroughs/01-create-project.md"
                        }
                    },
                    {
                        "id": "scaffold-files",
                        "title": "Scaffold C# files instantly",
                        "description": "Add classes, interfaces, structs, or records with the right namespace pre-filled — straight from the explorer or the command palette.",
                        "media": {
                            "markdown": "walkthroughs/02-scaffold-files.md"
                        }
                    },
                    {
                        "id": "modern-snippets",
                        "title": "Use modern C# snippets",
                        "description": "Type prefixes like `colexpr`, `pctor`, `reqprop`, `result`, `minimalapi` to expand fully-formed snippets.",
                        "media": {
                            "markdown": "walkthroughs/03-modern-snippets.md"
                        }
                    },
                    {
                        "id": "advanced",
                        "title": "Architecture scaffolds & patterns",
                        "description": "Scaffold complete Clean Architecture / DDD solutions, insert design patterns at the cursor, and quick-add curated NuGet packages.",
                        "media": {
                            "markdown": "walkthroughs/04-advanced.md"
                        }
                    }
                ]
            }
        ],
        "configuration": {
            "title": "C# Toolbox",
            "properties": {
                "csharp-snippet-productivity.defaultFolderForProjectCreation": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Set the default folder for project creation",
                    "default": null
                },
                "csharp-snippet-productivity.multilineComments": {
                    "type": "boolean",
                    "description": "Whether the multiline comment highlighter should be active",
                    "default": true
                },
                "csharp-snippet-productivity.highlightPlainText": {
                    "type": "boolean",
                    "description": "Whether the plaintext comment highlighter should be active",
                    "default": false
                },
                "csharp-snippet-productivity.telemetry.enabled": {
                    "type": "boolean",
                    "description": "Send anonymous usage telemetry (template usage counts, command invocations) to help improve the extension. Reset to false to opt out at any time. See PRIVACY.md for details on what is collected.",
                    "default": false
                },
                "csharp-snippet-productivity.nuget.popularPackages": {
                    "type": "array",
                    "description": "Curated list of NuGet packages shown in the 'Quick Add NuGet Package' picker. Each entry is a string in the form '<package-id>: <description>'.",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "Serilog.AspNetCore: Structured logging for ASP.NET Core",
                        "Serilog.Sinks.Console: Console sink for Serilog",
                        "Polly: Resilience and transient-fault-handling library",
                        "MediatR: Simple, unambitious mediator implementation",
                        "FluentValidation: Validation library for .NET",
                        "FluentValidation.AspNetCore: ASP.NET Core integration for FluentValidation",
                        "AutoMapper: Object-to-object mapping",
                        "Microsoft.EntityFrameworkCore: Entity Framework Core ORM",
                        "Microsoft.EntityFrameworkCore.SqlServer: SQL Server provider for EF Core",
                        "Microsoft.EntityFrameworkCore.Sqlite: SQLite provider for EF Core",
                        "Microsoft.EntityFrameworkCore.Design: Design-time tools for EF Core",
                        "Dapper: Lightweight micro-ORM",
                        "Newtonsoft.Json: JSON framework for .NET",
                        "Swashbuckle.AspNetCore: Swagger / OpenAPI for ASP.NET Core",
                        "Microsoft.Extensions.Http.Polly: Polly integration for HttpClientFactory",
                        "Microsoft.AspNetCore.Authentication.JwtBearer: JWT bearer authentication",
                        "BenchmarkDotNet: .NET benchmarking library",
                        "xunit: xUnit testing framework",
                        "xunit.runner.visualstudio: Visual Studio runner for xUnit",
                        "Moq: The most popular .NET mocking library",
                        "FluentAssertions: Fluent assertions for tests",
                        "NSubstitute: Friendly mocking framework",
                        "Bogus: Fake-data generator",
                        "Hangfire: Background job processing",
                        "MassTransit: Distributed application framework",
                        "Refit: Type-safe REST library"
                    ]
                },
                "csharp-snippet-productivity.tags": {
                    "type": "array",
                    "description": "Colored comments. Each entry highlights single-line comments whose first word matches the tag (e.g. '// TODO: refactor'). Edit colors and add custom tags here — changes apply live, no window reload needed.",
                    "default": [
                        {
                            "tag": "bug",
                            "color": "#FF2D00",
                            "strikethrough": false,
                            "underline": false,
                            "backgroundColor": "transparent",
                            "bold": true,
                            "italic": false
                        },
                        {
