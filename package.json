            }
        }
    },
    "galleryBanner": {
        "color": "#e3f4ff",
        "theme": "light"
    },
    "main": "./out/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "compile:test": "tsc -p tsconfig.test.json",
        "pretest": "npm run lint && npm run compile:test",
        "test": "node ./out-test/test/runTest.js",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/find-parent-dir": "^0.3.3",
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.6",
        "@types/node": "^20.11.0",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^6.18.1",
        "@typescript-eslint/parser": "^6.18.1",
        "eslint": "^8.56.0",
        "glob": "^10.3.10",
        "mocha": "^10.2.0",
        "typescript": "^5.3.3",
        "vscode-test": "^1.5.0"
    },
    "dependencies": {
        "find-parent-dir": "^0.3.1",
        "find-up-glob": "^1.0.0",
        "n-readlines": "^1.0.1",
        "os": "^0.1.2"
    }
}
